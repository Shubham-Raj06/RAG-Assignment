# Make My Education RAG — Environment Variable Reference
# Copy this file to .env and fill in your values.
# Never commit .env to version control (it is in .gitignore).

# ── Required ──────────────────────────────────────────────────────────────────

# Your Google AI Studio API key.
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-api-key-here

# ── Optional — all have sensible defaults ─────────────────────────────────────

# Gemini model to use for generation.
# Default: gemini-3.1-flash-lite (free-tier compatible, 100% eval pass rate)
# Paid-tier option: gemini-2.5-flash (stronger instruction-following, ~3x cost)
# MME_MODEL=gemini-3.1-flash-lite

# Minimum seconds between consecutive API calls (rate-limit guard).
# Free tier: 15 RPM → 4s minimum; 5s adds a safety margin.
# Paid tier: set to 0.1 or 0 to remove the delay.
# MME_CALL_INTERVAL_S=5.0

# Maximum number of retry attempts on retriable API errors (429, 503, 500).
# Attempt 1 + up to (N-1) retries. Default: 4 (3 retries).
# MME_MAX_RETRIES=4

# Fallback wait time in seconds when the API error message doesn't contain
# an explicit retry-after delay. Applied with exponential backoff.
# Default: 65.0s  (just over the 60s free-tier rate-limit window)
# MME_DEFAULT_WAIT_S=65.0
